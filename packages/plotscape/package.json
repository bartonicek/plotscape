{
  "name": "@abartonicek/plotscape",
  "version": "0.0.7",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist/main.js",
    "dist/main.css",
    "dist/main.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bartonicek/plotscape/tree/master/packages/plotscape"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bun run test && bun run compile && vite build && bun run pushR",
    "compile": "tsc --p ./tsconfig-build.json",
    "test": "bun test",
    "pushR": "cp ./dist/main.iife.js ../plotscaper/inst/htmlwidgets/plotscape"
  },
  "devDependencies": {
    "html2canvas": "^1.4.1",
    "@types/bun": "^1.1.0",
    "typescript": "^5.2.2",
    "utils": "workspace:*",
    "vite": "^5.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
